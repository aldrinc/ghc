{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VOC Item Observation Sheet",
  "description": "24 base fields + 5 video hook extension fields. Filled by Agent 2 for each VOC item.",
  "type": "object",
  "required": ["voc_id"],
  "properties": {
    "voc_id": { "type": "string", "pattern": "^V\\d{3,}$" },

    "specific_number": { "type": "string", "enum": ["Y", "N"] },
    "specific_product_brand": { "type": "string", "enum": ["Y", "N"] },
    "specific_event_moment": { "type": "string", "enum": ["Y", "N"] },
    "specific_body_symptom": { "type": "string", "enum": ["Y", "N"] },
    "before_after_comparison": { "type": "string", "enum": ["Y", "N"] },

    "crisis_language": { "type": "string", "enum": ["Y", "N"] },
    "profanity_extreme_punctuation": { "type": "string", "enum": ["Y", "N"] },
    "physical_sensation": { "type": "string", "enum": ["Y", "N"] },
    "identity_change_desire": { "type": "string", "enum": ["Y", "N"] },
    "word_count": { "type": "integer" },

    "clear_trigger_event": { "type": "string", "enum": ["Y", "N"] },
    "named_enemy": { "type": "string", "enum": ["Y", "N"] },
    "shiftable_belief": { "type": "string", "enum": ["Y", "N"] },
    "expectation_vs_reality": { "type": "string", "enum": ["Y", "N"] },
    "headline_ready": { "type": "string", "enum": ["Y", "N"] },

    "personal_context": { "type": "string", "enum": ["Y", "N"] },
    "long_narrative": { "type": "string", "enum": ["Y", "N"] },
    "engagement_received": { "type": "string", "enum": ["Y", "N"] },
    "real_person_signals": { "type": "string", "enum": ["Y", "N"] },
    "moderated_community": { "type": "string", "enum": ["Y", "N"] },

    "usable_content_pct": { "type": "string", "enum": ["OVER_75_PCT", "50_TO_75_PCT", "25_TO_50_PCT", "UNDER_25_PCT"] },

    "date_bracket": { "type": "string", "enum": ["LAST_3MO", "LAST_6MO", "LAST_12MO", "LAST_24MO", "OLDER", "UNKNOWN"] },
    "durable_psychology": { "type": "string", "enum": ["Y", "N"] },
    "market_specific": { "type": "string", "enum": ["Y", "N"] },

    "source_type": {
      "type": "string",
      "enum": ["REDDIT", "FORUM", "BLOG_COMMENT", "REVIEW_SITE", "QA", "YOUTUBE", "FB_GROUP", "COMPETITOR_ADJACENT", "TIKTOK_COMMENT", "IG_COMMENT", "YT_COMMENT", "VIDEO_HOOK"],
      "description": "v2 expansion: includes social video source types"
    },

    "is_hook": {
      "type": "string",
      "enum": ["Y", "N"],
      "description": "v2: Is this item a video hook (vs. a comment). Only applies to VIDEO_HOOK source_type."
    },
    "hook_format": {
      "type": "string",
      "enum": ["QUESTION", "STATEMENT", "CONTROVERSY", "STORY_OPEN", "PATTERN_INTERRUPT", "NONE"],
      "description": "v2: Hook structure type. Only applies when is_hook=Y."
    },
    "hook_word_count": {
      "type": "integer",
      "description": "v2: Length of hook (first 3-5 seconds transcribed). Only applies when is_hook=Y."
    },
    "video_virality_tier": {
      "type": "string",
      "enum": ["VIRAL", "HIGH_PERFORMING", "ABOVE_AVERAGE", "BASELINE", "HIGH_AUTHORITY"],
      "description": "v2: From score_virality.py. Only applies to video-sourced items."
    },
    "video_view_count": {
      "type": "integer",
      "description": "v2: Raw view count for context. Only applies to video-sourced items."
    },

    "trigger_event": { "type": ["string", "null"] },
    "pain_problem": { "type": ["string", "null"] },
    "desired_outcome": { "type": ["string", "null"] },
    "failed_prior_solution": { "type": ["string", "null"] },
    "enemy_blame": { "type": ["string", "null"] },
    "identity_role": { "type": ["string", "null"] },
    "fear_risk": { "type": ["string", "null"] },
    "emotional_valence": {
      "type": "string",
      "enum": ["RELIEF", "RAGE", "SHAME", "PRIDE", "ANXIETY", "HOPE", "FRUSTRATION", "NEUTRAL"]
    },

    "buyer_stage": {
      "type": "string",
      "enum": ["UNAWARE", "PROBLEM_AWARE", "SOLUTION_AWARE", "PRODUCT_AWARE", "MOST_AWARE"]
    },
    "solution_sophistication": {
      "type": "string",
      "enum": ["NOVICE", "EXPERIENCED", "EXHAUSTED"]
    },
    "compliance_risk": {
      "type": "string",
      "enum": ["GREEN", "YELLOW", "RED"]
    }
  }
}
