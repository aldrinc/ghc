  "rules": [
    {
      "ruleId": "META-ACCOUNT-001",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "account_setup",
      "severity": "blocker",
      "requirement": "Business Manager must be configured for the client before Meta launch review.",
      "policyAnchorQuote": null,
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.operator_ads_manager_setup_checklist",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["platform_profile", "campaign"],
      "fixGuidance": ["Set the Business Manager ID and name on the Meta platform profile."],
      "commonFailureExamples": ["No Business Manager is recorded for the client."]
    },
    {
      "ruleId": "META-ACCOUNT-002",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "account_setup",
      "severity": "blocker",
      "requirement": "A Page must be configured for Meta launch review.",
      "policyAnchorQuote": null,
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.operator_ads_manager_setup_checklist",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["platform_profile", "campaign"],
      "fixGuidance": ["Set the Meta Page ID on the platform profile."],
      "commonFailureExamples": ["Page ID is empty."]
    },
    {
      "ruleId": "META-ACCOUNT-003",
