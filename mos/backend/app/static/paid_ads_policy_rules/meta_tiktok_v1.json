      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.operator_ads_manager_setup_checklist",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["platform_profile", "campaign"],
      "fixGuidance": ["Set verifiedDomain and verifiedDomainStatus=verified."],
      "commonFailureExamples": ["Domain status is unverified."]
    },
    {
      "ruleId": "META-ACCOUNT-010",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "account_setup",
      "severity": "high",
      "requirement": "Attribution should be configured as 7-day click and 1-day view for launch review.",
      "policyAnchorQuote": null,
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.operator_ads_manager_setup_checklist",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["platform_profile", "campaign"],
      "fixGuidance": [
        "Set attributionClickWindow=7d.",
        "Set attributionViewWindow=1d."
      ],
      "commonFailureExamples": ["Attribution windows differ from 7d click / 1d view."]
    },
    {
      "ruleId": "META-ACCOUNT-011",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "account_setup",
