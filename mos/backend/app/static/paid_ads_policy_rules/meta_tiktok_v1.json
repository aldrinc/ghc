      "commonFailureExamples": ["destinationUrl is a relative path only."]
    },
    {
      "ruleId": "META-LP-003",
      "ruleType": "policy",
      "platform": "meta",
      "domain": "landing_page",
      "severity": "blocker",
      "requirement": "The landing page must be reachable and functional for launch review.",
      "policyAnchorQuote": "Ads must not violate our Community Standards.",
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.community_standards",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["campaign", "creative_spec"],
      "fixGuidance": ["Fix the destination URL or publish the page before launch review."],
      "commonFailureExamples": ["Destination returns 404.", "Destination cannot be fetched."]
    },
    {
      "ruleId": "META-LP-004",
      "ruleType": "policy",
      "platform": "meta",
      "domain": "landing_page",
      "severity": "blocker",
      "requirement": "Landing pages that are under construction or obviously incomplete should fail launch review.",
      "policyAnchorQuote": "Ads must not violate our Community Standards.",
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.community_standards",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["campaign", "creative_spec"],
      "fixGuidance": ["Remove placeholder or under-construction content and publish the final page."],
      "commonFailureExamples": ["Under construction.", "Coming soon."]
    },
