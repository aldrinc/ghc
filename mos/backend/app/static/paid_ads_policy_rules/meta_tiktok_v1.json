    {
      "ruleId": "META-ACCOUNT-007",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "account_setup",
      "severity": "blocker",
      "requirement": "Meta Data Set must be configured and assigned to the Ad Account before launch review.",
      "policyAnchorQuote": null,
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.operator_ads_manager_setup_checklist",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["platform_profile", "campaign"],
      "fixGuidance": ["Set dataSetId and mark dataSetAssignedToAdAccount=true."],
      "commonFailureExamples": ["Data Set is missing or not assigned to the ad account."]
    },
    {
      "ruleId": "META-ACCOUNT-008",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "account_setup",
      "severity": "high",
      "requirement": "Meta Data Set should be installed through the Shopify partner path and use Maximum data sharing.",
      "policyAnchorQuote": null,
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.operator_ads_manager_setup_checklist",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["platform_profile", "campaign"],
      "fixGuidance": [
        "Set dataSetShopifyPartnerInstalled=true.",
        "Set dataSetDataSharingLevel=maximum."
      ],
      "commonFailureExamples": ["Data sharing level is not maximum."]
    },
    {
      "ruleId": "META-ACCOUNT-009",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "account_setup",
      "severity": "blocker",
