      "commonFailureExamples": ["Campaign has no Meta ad set specs."]
    },
    {
      "ruleId": "META-COPY-002",
      "ruleType": "policy",
      "platform": "meta",
      "domain": "copy",
      "severity": "blocker",
      "requirement": "Ads must not share or ask for private information or imply knowledge of private user information.",
      "policyAnchorQuote": "Ads must not contain content that shares or asks for private information about users.",
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.privacy_personal_attributes",
      "sourceNeedsVerification": false,
      "appliesToObjects": ["campaign", "creative_spec"],
      "fixGuidance": ["Remove personal-attribute framing or private-information prompts from the copy."],
      "commonFailureExamples": ["We know you have diabetes.", "Enter your SSN here."]
    },
    {
      "ruleId": "META-COPY-003",
      "ruleType": "policy",
      "platform": "meta",
      "domain": "copy",
      "severity": "blocker",
      "requirement": "Ads must not discriminate or encourage discrimination.",
      "policyAnchorQuote": "Ads must not discriminate or encourage discrimination",
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.discriminatory_practices",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["campaign", "creative_spec"],
      "fixGuidance": ["Remove exclusionary or discriminatory language from the copy."],
      "commonFailureExamples": ["Not for seniors.", "Only for women."]
    },
    {
      "ruleId": "META-COPY-004",
      "ruleType": "policy",
      "platform": "meta",
      "domain": "copy",
      "severity": "high",
      "requirement": "Potential social issues, elections, or politics content requires authorization and disclaimer review.",
      "policyAnchorQuote": "include a verified \"Paid for by\" disclaimer",
      "automated": true,
      "manualReviewRequired": true,
      "sourceId": "meta.siep",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["campaign", "creative_spec"],
      "fixGuidance": ["Review SIEP authorization requirements and add a verified disclaimer if applicable."],
      "commonFailureExamples": ["Vote for candidate X.", "Support this ballot measure."]
    },
    {
      "ruleId": "META-COPY-005",
      "ruleType": "policy",
      "platform": "meta",
      "domain": "copy",
      "severity": "high",
      "requirement": "Ads must not imply or attempt to generate negative self-perception.",
      "policyAnchorQuote": "Ads must not imply or attempt to generate negative self-perception",
      "automated": true,
      "manualReviewRequired": false,
      "sourceId": "meta.health_wellness",
      "sourceNeedsVerification": true,
      "appliesToObjects": ["campaign", "creative_spec"],
      "fixGuidance": ["Remove body-shaming or humiliation-based language from the copy."],
      "commonFailureExamples": ["Are you fat?", "Stop being ugly."]
    },
    {
      "ruleId": "META-LP-001",
      "ruleType": "operational_readiness",
      "platform": "meta",
      "domain": "landing_page",
